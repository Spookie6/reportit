<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.SVGPath?>

<AnchorPane onMouseDragged="#onWindowDragged" onMousePressed="#onWindowPressed" prefHeight="740" prefWidth="390" stylesheets="@Home.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="PageController">

    <children>
        <Region styleClass="bg" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0" />

        <Label fx:id="lblWelcome" layoutX="28" layoutY="42" styleClass="h1" text="Welcome, user" />

        <StackPane layoutX="0" layoutY="250" prefHeight="260" prefWidth="390">
            <Circle radius="122" styleClass="avatar-outer" />

            <Circle fx:id="profileCircle" fill="lightgray" radius="110" />
        </StackPane>

        <StackPane fx:id="moodContainer" layoutX="65" layoutY="520" onMouseClicked="#onMoodClicked" prefHeight="70" prefWidth="260" styleClass="mood-pill">
            <HBox alignment="CENTER_LEFT">
                <padding>
                    <Insets bottom="0" left="22" right="22" top="0" />
                </padding>
                <Label styleClass="mood-text" text="Mood," />
                <Label fx:id="lblMoodValue" styleClass="mood-bad" text=" Bad" />
                <Region HBox.hgrow="ALWAYS" />
                <SVGPath content="M4 6 L12 14 L20 6" styleClass="chev" />
            </HBox>
        </StackPane>

        <StackPane styleClass="navBar" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <HBox alignment="CENTER" spacing="54">
                <SVGPath fx:id="btnHome" content="M12 3 L3 11 L3 23 L10 23 L10 16 L14 16 L14 23 L21 23 L21 11 Z" onMouseClicked="#onHomeClicked" pickOnBounds="true" styleClass="navIcon" />

                <StackPane fx:id="btnAdd" onMouseClicked="#onAddClicked" styleClass="plusButton">
                    <Label styleClass="plusText" text="+" />
                </StackPane>

                <SVGPath fx:id="btnThreads" content="M3 6 H21 V18 H12 L8 22 V18 H3 Z" onMouseClicked="#onThreadsClicked" pickOnBounds="true" styleClass="navIcon" />
            </HBox>
        </StackPane>

    </children>
</AnchorPane>
