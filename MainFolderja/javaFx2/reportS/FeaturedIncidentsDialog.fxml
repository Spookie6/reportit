<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="PageController"
           stylesheets="@report.css" styleClass="dialogOverlay">
    <VBox spacing="12" styleClass="dialogCard" maxWidth="420">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="Featured incidents" styleClass="dialogTitle"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Close" onAction="#onClose" styleClass="ghostBtn"/>
        </HBox>

        <Label text="The 10 most recent incidents reported by the community." styleClass="muted"/>

        <VBox fx:id="featuredContainer" spacing="10">
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Button text="Done" onAction="#onClose" styleClass="primaryBtn"/>
        </HBox>
    </VBox>
</StackPane>